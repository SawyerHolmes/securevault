{
    "manifest_version": 3,
    "name": "Securevault",
    "short_name": "Securevault",
    "version": "0.2.0",
    "description": "Companion extension for Securevault. Detects login forms and fills credentials from your hosted vault.",
    "action": {
        "default_title": "Securevault",
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "storage",
        "tabs",
        "activeTab"
    ],
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js":      ["content.js"],
            "css":     ["content.css"],
            "run_at":  "document_idle"
        }
    ],
    "options_page": "options.html"
}
